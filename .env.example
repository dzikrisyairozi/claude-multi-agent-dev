# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ---- Required ----

# GitHub personal access token with `repo` and `project` scopes.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Owner of the target repository (username or organization).
GITHUB_OWNER=your-github-username

# Repository name where tickets, branches, and PRs will live.
GITHUB_REPO=your-repo-name

# ---- Optional ----

# Figma personal access token. If set, the uiux-designer agent can pull
# design specs from Figma via MCP. If unset, the agent writes specs from scratch.
FIGMA_TOKEN=

# Port the local orchestration dashboard listens on. Default: 3456.
DASHBOARD_PORT=3456
