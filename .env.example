# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ---- Required ----

# GitHub personal access token with `repo` scope (full repository access).
# Create a classic token at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Owner of the target repository (username or organization).
GITHUB_OWNER=your-github-username

# Repository name where tickets, branches, and PRs will live.
GITHUB_REPO=your-repo-name

# ---- Optional ----

# Port the local orchestration dashboard listens on. Default: 3456.
DASHBOARD_PORT=3456

# How often the dashboard polls GitHub for ticket state, in milliseconds.
# Minimum 5000, default 10000. Lower = more responsive, higher = fewer API calls.
GITHUB_POLL_MS=10000
